{
    "name": "ffmpeg-8.1-full_build.7z",
    "savedir": "编程工具",
    "version": "1.0",
    "description": "完整版音视频处理工具",
    "homepage": "https://ffmpeg.org/",
    "license": "MIT",
    "url": "https://github.com/GyanD/codexffmpeg/releases/download/8.1/ffmpeg-8.1-full_build.7z",
    "hash": "auto",
    "extract_dir": "ffmpeg-8.1-full_build",
    "bin": [
        "bin/ffmpeg.exe",
        "bin/ffprobe.exe",
        "bin/ffplay.exe"
    ],
    "checkver": [
        {
            "url": "https://api.github.com/repos/GyanD/codexffmpeg/releases/latest",
            "jsonpath": "$.tag_name",
            "regex": "(?<version>.+)"
        },
        {
            "url": "https://api.github.com/repos/GyanD/codexffmpeg/releases/latest",
            "jsonpath": "$..browser_download_url",
            "regex": "([^/]+full_build\\.7z)$",
            "variable": "filename"
        }
    ],
    "autoupdate": {
        "url": "https://github.com/GyanD/codexffmpeg/releases/download/$version/$filename",
        "name": "$filename"
    }
}